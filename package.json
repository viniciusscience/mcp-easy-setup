{
  "name": "mcp-easy-setup",
  "displayName": "MCP Easy Setup",
  "description": "Extensão guiada para criar integrações MCP de serviços internos sem lidar com JSON manual ou configuração complicada.",
  "version": "0.0.2",
  "publisher": "Joseviniciusdasilvadesouzadesouza",
  "repository": {
    "type": "git",
    "url": "https://github.com/viniciusscience/mcp-easy-setup.git"
  },
  "license": "MIT",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.125.0"
  },
  "categories": [
    "Other",
    "AI"
  ],
  "activationEvents": [
    "onCommand:mcpEasySetup.searchMcp"
  ],
  "browser": "./dist/web/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "mcpEasySetup.searchMcp",
        "title": "MCP Easy Setup"
      }
    ]
  },
  "scripts": {
    "test": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/suite/extensionTests.js",
    "pretest": "npm run compile-web",
    "vscode:prepublish": "npm run package-web",
    "compile-web": "npm run check-types && npm run lint && node esbuild.js",
    "watch-web": "npm-run-all -p watch-web:*",
    "watch-web:esbuild": "node esbuild.js --watch",
    "watch-web:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package-web": "npm run check-types && npm run lint && node esbuild.js --production",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@types/vscode": "^1.125.0",
    "@types/mocha": "^10.0.10",
    "@types/assert": "^1.5.11",
    "eslint": "^10.5.0",
    "typescript-eslint": "^8.61.1",
    "mocha": "^11.7.6",
    "typescript": "^6.0.3",
    "@vscode/test-web": "^0.0.81",
    "esbuild": "^0.28.1",
    "glob": "^13.0.6",
    "npm-run-all": "^4.1.5",
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "assert": "^2.1.0"
  },
  "overrides": {
    "diff": "^8.0.4",
    "serialize-javascript": "^7.0.6"
  }
}
